# ─────────────────────────────────────────────────────────────
# .env — Variables d'environnement
# Projet : Surveillance Sphère GPL — District NAFTAL Batna
#
# ⚠️  Copiez ce fichier en ".env" et remplissez vos valeurs.
#     Ne commitez JAMAIS le fichier .env sur GitHub.
# ─────────────────────────────────────────────────────────────

# ── MQTT Broker ───────────────────────────────────────────────
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_TOPIC=tank/+/data

# ── InfluxDB ──────────────────────────────────────────────────
INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=gpl-super-secret-token-changeme
INFLUX_ORG=naftal
INFLUX_BUCKET=gpl_metrics
INFLUX_USER=admin
INFLUX_PASSWORD=adminpassword123

# ── Backend server ────────────────────────────────────────────
PORT=3001

# ── Email alerts (Nodemailer / Gmail) ─────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=votre.email@gmail.com
MAIL_PASS=votre_app_password
MAIL_TO=equipe.gpl@naftal.dz
